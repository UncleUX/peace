      // Gestion de la vidéo promotionnelle
      document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('promotionalVideoModal');
        const video = document.getElementById('promotional-video-modal');
        
        if (modal && video) {
          // Lancer la vidéo quand le modal s'ouvre
          modal.addEventListener('shown.bs.modal', function () {
            // Petit délai pour s'assurer que le modal est complètement visible
            setTimeout(() => {
              video.play().catch(function(error) {
                console.log('Autoplay bloqué par le navigateur:', error);
              });
            }, 300);
          });
          
          // Arrêter la vidéo quand le modal se ferme
