<script>
// Fonction de confirmation pour le démarrage du quiz avec SweetAlert2
function confirmQuizStart(lessonId, questionCount, lessonTitle) {
    const plural = questionCount > 1 ? 's' : '';
    
    Swal.fire({
        title: `${lessonTitle}`,
        html: `<div class="text-start">
                 <p>Cette leçon contient ${questionCount} question${plural}.</p>
                 <p class="mb-0">Voulez-vous commencer maintenant ?</p>
              </div>`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Commencer',
        cancelButtonText: 'Annuler',
        confirmButtonColor: '#0d6efd',
        cancelButtonColor: '#6c757d',
        reverseButtons: true,
        customClass: {
            confirmButton: 'btn btn-primary',
            cancelButton: 'btn btn-outline-secondary me-2'
        },
        buttonsStyling: false
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/exercices/lesson/${lessonId}/quiz/`;
        }
    });
}

// Fonction pour animer le cercle de progression
function animateCircularProgress() {
    const progressElements = document.querySelectorAll('.circular-progress');
    
    progressElements.forEach(progress => {
        const percent = progress.getAttribute('data-percent');
        const progressValue = progress.querySelector('.progress-value');
        
        // Mettre à jour la variable CSS avec la valeur du pourcentage
        progress.style.setProperty('--progress-value', percent);
        
        // Pour les navigateurs qui ne supportent pas @property
        if (!CSS.supports('background', 'paint(something)')) {
            progress.style.background = `conic-gradient(
                ${progress.style.getPropertyValue('--progress-color') || '#28a745'} ${percent}%,
                #e9ecef 0
            )`;
        }
        
        // Animation du compteur
        let startValue = 0;
        const duration = 1500; // 1.5 secondes
        const increment = percent / (duration / 16); // 60fps
        
        const timer = setInterval(() => {
            startValue += increment;
            if (startValue >= percent) {
                startValue = percent;
                clearInterval(timer);
            }
            progressValue.textContent = `${Math.round(startValue)}%`;
        }, 16);
    });
}

document.addEventListener('DOMContentLoaded', function() {
    // Animer les cercles de progression
    if (document.querySelector('.circular-progress')) {
        animateCircularProgress();
    }
    // Gestion de la sidebar
    document.querySelectorAll('.sidebar a').forEach(link => {
        link.addEventListener('click', function(e) {
            // Si c'est un lien #, empêcher le comportement par défaut
            if (this.getAttribute('href') === '#') {
                e.preventDefault();
                
                // Retirer la classe active de toutes les icônes
                document.querySelectorAll('.sidebar .icon').forEach(icon => {
                    icon.classList.remove('active');
                });
                
                // Ajouter la classe active à l'icône cliquée
                this.classList.add('active');
                
                // Récupérer l'icône cliquée
                const iconElement = this.querySelector('i');
                const iconClass = Array.from(iconElement.classList).find(cls => cls.startsWith('bi-'));
                
                if (!iconClass) return;
                
                // Actions spécifiques pour chaque icône
                if (iconClass === 'bi-gear') {
                    // Afficher un message pour les paramètres
                    showToast('Paramètres', 'Accès aux paramètres du compte', 'info');
                }
            } else {
                // Pour les liens normaux, la redirection se fera automatiquement
                // On ne fait rien ici, le comportement par défaut du navigateur s'occupe de la redirection
            }
        });
    });
    
    // Gestion du clic sur l'icône du contenu du cours (qui n'est pas dans un lien <a>)
    document.querySelector('.sidebar > .icon:first-child').addEventListener('click', function() {
        // Retirer la classe active de toutes les icônes
        document.querySelectorAll('.sidebar .icon').forEach(icon => {
            icon.classList.remove('active');
        });
        
        // Ajouter la classe active à l'icône cliquée
        this.classList.add('active');
        
        // Afficher le contenu principal du cours
        document.querySelector('.ld-tabs').style.display = 'block';
        document.querySelector('.panel').style.display = 'block';
    });

    // Gestion du formulaire de marquage du cours comme terminé
    document.querySelectorAll('.mark-course-completed-form').forEach(form => {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const button = this.querySelector('button[type="submit"]');
            const icon = button.querySelector('i');
            const formData = new FormData(this);
            
            // Désactiver le bouton pendant la requête
            button.disabled = true;
            
            // Mise à jour immédiate de l'interface utilisateur
            const isCurrentlyCompleted = button.classList.contains('btn-success');
            
            // Envoyer la requête au serveur
            fetch(this.action, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRFToken': formData.get('csrfmiddlewaretoken')
                },
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Erreur réseau');
                }
                return response.json();
            })
            .then(data => {
                if (data.status === 'success') {
                    // Mettre à jour l'interface utilisateur
                    if (data.completed) {
                        button.classList.remove('btn-outline-primary');
                        button.classList.add('btn-success');
                        icon.className = 'bi bi-check-circle-fill me-1';
                        button.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Cours terminé';
                        button.disabled = true;
                        
                        // Mettre à jour la barre de progression
                        if (data.progress) {
                            const progressBar = document.querySelector('.progress-bar');
                            const progressText = document.querySelector('.progress-wrap .fw-bold');
                            const progressCount = document.querySelector('.progress-wrap .small');
                            
                            if (progressBar && progressText && progressCount) {
                                progressBar.style.width = `${data.progress.percent}%`;
                                progressBar.setAttribute('aria-valuenow', data.progress.percent);
                                progressText.textContent = `${data.progress.percent}%`;
                                progressCount.textContent = `${data.progress.completed}/${data.progress.total} leçon${data.progress.total > 1 ? 's' : ''}`;
                            }
                        }
                        
                        showToast('Succès', data.message, 'success');
                    } else {
                        button.classList.remove('btn-success');
                        button.classList.add('btn-outline-primary');
                        icon.className = 'bi bi-circle me-1';
                        button.innerHTML = '<i class="bi bi-circle me-1"></i> Marquer comme terminé';
                        showToast('Succès', data.message, 'info');
                    }
                } else {
                    throw new Error(data.message || 'Erreur lors de la mise à jour');
                }
            })
            .catch(error => {
                console.error('Erreur:', error);
                showToast('Erreur', error.message || 'Une erreur est survenue. Veuillez réessayer.', 'error');
            })
            .finally(() => {
                if (!isCurrentlyCompleted) {
                    button.disabled = isCurrentlyCompleted;
                }
            });
        });
    });
    
    // Fonction utilitaire pour afficher des notifications
    function showToast(title, message, type = 'info') {
        // Utiliser Toastify, SweetAlert2 ou tout autre système de notification
        // Par exemple, avec SweetAlert2 :
        if (typeof Swal !== 'undefined') {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer);
                    toast.addEventListener('mouseleave', Swal.resumeTimer);
                }
            });
            
            Toast.fire({
                icon: type,
                title: title,
                text: message
            });
        } else if (typeof toastr !== 'undefined') {
            // Ou utiliser toastr
            toastr[type](message, title);
        } else {
            // Fallback à une alerte native
            alert(`${title}: ${message}`);
        }
    }
});
</script>
<script>
  const {children: titles} = document.querySelector(".animate-text");
const txtsLen = titles.length;
let index = 0;
const textInTimer = 9000;
const textOutTimer = 9000;

function animateText() {
  for (let i = 0; i < txtsLen; i++) {
    titles[i].classList.remove("text-in", "text-out");
  }
  titles[index].classList.add("text-in");

  setTimeout(function () {
    titles[index].classList.add("text-out");
  }, textOutTimer);

  setTimeout(function () {
    if (index == txtsLen - 1) {
      index = 0;
    } else {
      index++;
    }
    animateText();
  }, textInTimer);
}

window.onload = animateText;
</script>
